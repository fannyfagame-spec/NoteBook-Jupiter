      "id": "755cbebb",
      "metadata": {
        "id": "755cbebb",
        "outputId": "fd5e6654-cbd2-45f7-d519-d1f9ea5ca8c2",
        "colab": {
          "base_uri": "https://localhost:8080/"
        }
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Masukkan nama film (atau ketik 'exit' untuk keluar): Batman\n",
            "Masukkan umur kamu: 18\n",
            "Tiket berhasil dipesan.\n",
            "Sisa tiket: 4\n",
            "Masukkan nama film (atau ketik 'exit' untuk keluar): exit\n"
          ]
        }
      ],
      "source": [
        "\n",
        "# create a dictionary of movies with key: value pair as \"Movie Name\": [age criteria, no of tickets available]\n",
        "\n",
        "movies = {\n",
        "    \"Finding Nemo\": [5, 2],\n",
        "    \"Moana\": [6, 3],\n",
        "    \"Batman\": [18, 5],\n",
        "    \"The Lion King\": [10, 4]\n",
        "}\n",
        "\n",
        "# create a while loop to run continuously\n",
        "while True:\n",
        "\n",
        "    # Take input from the user which movie they would like to watch\n",
        "    # strip off the blankspaces and convert to title case\n",
        "    choice = input(\"Masukkan nama film (atau ketik 'exit' untuk keluar): \").strip().title()\n",
        "\n",
        "    if choice == \"Exit\":\n",
        "        break\n",
        "\n",
        "    # Create a conditional logic using if:\n",
        "    # if specified movie is present in the dictionary then continue\n",
        "    if choice in movies:\n",
        "\n",
        "        # ask the user for age\n",
        "        age = int(input(\"Masukkan umur kamu: \"))\n",
        "\n",
        "        # check the user for age eligibility\n",
        "        if age >= movies[choice][0]:\n",
        "\n",
        "            # if eligible check for availability of seats\n",
        "            if movies[choice][1] > 0:\n",
        "\n",
        "                # if available, no of seats will reduce by 1\n",
        "                movies[choice][1] -= 1\n",
        "                print(\"Tiket berhasil dipesan.\")\n",
        "                print(\"Sisa tiket:\", movies[choice][1])\n",
        "\n",
        "            else:\n",
        "                print(\"Maaf, tiket sudah habis.\")\n",
        "\n",
        "        else:\n",
        "            print(\"Umur kamu belum memenuhi syarat untuk film ini.\")\n",
        "\n",
        "    else:\n",
        "        print(\"Film tidak ditemukan.\")"
      ]
    },
